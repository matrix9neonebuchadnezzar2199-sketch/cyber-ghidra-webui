# Copy to .env and adjust. docker-compose reads .env from the project root when present.

# --- Ghidra / worker ---
GHIDRA_HOME=/opt/ghidra
GHIDRA_TIMEOUT_SEC=600
GHIDRA_PROJECT_ROOT=/workspace/ghidra_projects
WORKER_POLL_SEC=2

# --- Frontend (Vite; also set in docker-compose for the frontend service) ---
VITE_API_URL=http://localhost:8000

