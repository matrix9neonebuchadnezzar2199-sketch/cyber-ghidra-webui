# Copy to .env and adjust. docker-compose reads .env from the project root when present.

# --- Ghidra / worker ---
GHIDRA_HOME=/opt/ghidra
GHIDRA_TIMEOUT_SEC=600
GHIDRA_PROJECT_ROOT=/workspace/ghidra_projects
WORKER_POLL_SEC=2

# --- Backend (FastAPI) ---
# Comma-separated origins for CORS (default if unset: http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000

# --- Frontend (Vite; also set in docker-compose for the frontend service) ---
VITE_API_URL=http://localhost:8000

# --- LLM annotation (Phase 2b; host Ollama / LM Studio) ---
# LLM_API_URL=http://host.docker.internal:11434/v1
# LLM_MODEL=llama3
# LLM_TIMEOUT_SEC=120
# LLM_USE_JSON_MODE=1
# If your server rejects response_format, use LLM_USE_JSON_MODE=0
